# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_CHANNEL_ID=C01234567

# AWS provisioning (populated after infra deploy)
AWS_API_URL=https://your-api-gateway-url/provision
SSO_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxxxxxxxxxx

# DynamoDB table names (must match CDK stack outputs)
DYNAMODB_TABLE_NAME=ak-aws-access-vending-access-records
PENDING_REQUESTS_TABLE=ak-aws-access-vending-pending-requests

# SNS (populated after infra deploy)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ak-access-vendor-notifications

# App config
AWS_REGION=us-east-1
ALLOWED_EMAIL_DOMAIN=armakuni.com
SES_FROM_EMAIL=noreply@armakuni.com

# Optional: static fallback account list for local dev (format: id:Name,id:Name)
# AWS_ACCOUNT_IDS=123456789012:Production,234567890123:Staging
